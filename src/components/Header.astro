
---
import HeaderLink from './HeaderLink.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';

const isES = Astro.url.pathname.startsWith('/es');

const t = isES
  ? { home: 'Inicio', services: 'Servicios', about: 'Nosotros', contact: 'Contacto' }
  : { home: 'Home', services: 'Services', about: 'About', contact: 'Contact' };
---

<header class="topbar">
  <nav class="nav">
	<a class="brand" href="#inicio">
		<img class="logo" src="/logo-dankenet.png" alt="DANKE.NET" loading="eager" />
	</a>

    <div class="links">
      <HeaderLink href="#inicio">{t.home}</HeaderLink>
      <HeaderLink href="#servicios">{t.services}</HeaderLink>
      <HeaderLink href="#nosotros">{t.about}</HeaderLink>
      <HeaderLink href="#contacto">{t.contact}</HeaderLink>
    </div>

    <div class="right">
      <LanguageSwitcher />
    </div>
  </nav>
</header>

<style>
  .topbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    background: linear-gradient(180deg, rgba(28, 31, 35, 0.98), rgba(28, 31, 35, 0.92));
    border-bottom: 1px solid rgba(79, 163, 255, 0.2);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
    transition: all 0.3s ease;
  }

  .topbar:hover {
    background: linear-gradient(180deg, rgba(28, 31, 35, 0.99), rgba(28, 31, 35, 0.95));
    border-bottom: 1px solid rgba(79, 163, 255, 0.3);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
  }

  .nav {
    max-width: 1120px;
    margin: 0 auto;
    padding: 16px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .brand{
    padding: 8px 14px;
    border-radius: 12px;
    background: rgba(79, 163, 255, 0.1);
    border: 1px solid rgba(79, 163, 255, 0.3);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .brand:hover {
    background: rgba(79, 163, 255, 0.15);
    border-color: rgba(79, 163, 255, 0.5);
    transform: scale(1.05);
  }

  .logo{
    height: 40px;
    width: auto;
    filter: drop-shadow(0 0 12px rgba(79, 163, 255, 0.4));
    transition: all 0.3s ease;
  }

  .brand:hover .logo {
    filter: drop-shadow(0 0 20px rgba(79, 163, 255, 0.6));
  }

  .links {
    display: flex;
    align-items: center;
    gap: 8px;
    flex: 1;
    justify-content: center;
  }

  .right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  @media (max-width: 860px) {
    .links { display: none; }
    
    .nav {
      padding: 12px 16px;
      gap: 12px;
    }

    .brand {
      padding: 6px 10px;
    }

    .logo {
      height: 32px;
    }
  }
</style>
