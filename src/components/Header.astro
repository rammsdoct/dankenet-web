
---
import HeaderLink from './HeaderLink.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';

const isES = Astro.url.pathname.startsWith('/es');

const t = isES
  ? { home: 'Inicio', services: 'Servicios', about: 'Nosotros', contact: 'Contacto' }
  : { home: 'Home', services: 'Services', about: 'About', contact: 'Contact' };
---

<header class="topbar">
  <nav class="nav">
	<a class="brand" href="#inicio">
		<img class="logo" src="/logo-dankenet.png" alt="DANKE.NET" loading="eager" />
	</a>

    <button class="hamburger" aria-label="Open menu" aria-expanded="false" type="button">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <div class="links" role="menubar">
      <HeaderLink href="#inicio" class="nav-link">{t.home}</HeaderLink>
      <HeaderLink href="#servicios" class="nav-link">{t.services}</HeaderLink>
      <HeaderLink href="#nosotros" class="nav-link">{t.about}</HeaderLink>
      <HeaderLink href="#transcender" class="nav-link">Transcend</HeaderLink>
      <HeaderLink href="#contacto" class="nav-link">{t.contact}</HeaderLink>
    </div>

    <div class="right">
      <LanguageSwitcher />
    </div>

    <div class="mobile-menu" id="mobileMenu" aria-hidden="true">
      <button class="mobile-close" aria-label="Close menu">×</button>
      <HeaderLink href="#inicio" class="mobile-link">{t.home}</HeaderLink>
      <HeaderLink href="#servicios" class="mobile-link">{t.services}</HeaderLink>
      <HeaderLink href="#nosotros" class="mobile-link">{t.about}</HeaderLink>
      <HeaderLink href="#contacto" class="mobile-link">{t.contact}</HeaderLink>
      <div class="mobile-lang">
        <LanguageSwitcher />
      </div>
    </div>
  </nav>
</header>

<style>
  .topbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    background: linear-gradient(180deg, rgba(28, 31, 35, 0.98), rgba(28, 31, 35, 0.92));
    border-bottom: 1px solid rgba(79, 163, 255, 0.2);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
    transition: all 0.3s ease;
  }

  .topbar:hover {
    background: linear-gradient(180deg, rgba(28, 31, 35, 0.99), rgba(28, 31, 35, 0.95));
    border-bottom: 1px solid rgba(79, 163, 255, 0.3);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
  }

  .nav {
    max-width: 1120px;
    margin: 0 auto;
    padding: 16px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    position: relative;
  }

  .hamburger {
    display: none;
    background: transparent;
    border: 0;
    width: 28px;
    height: 26px;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
    z-index: 20;
  }

  .hamburger span {
    display: block;
    height: 2px;
    width: 100%;
    background: #b6d9ff;
    margin: 5px 0;
    border-radius: 999px;
    transition: transform .25s ease, opacity .25s ease;
  }

  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(10, 14, 22, 0.94);
    color: white;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 18px;
    padding: 3rem 2rem;
    transform: translateY(-100%);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.3s ease, opacity 0.3s ease;
    z-index: 19;
  }

  .mobile-menu.open {
    transform: translateY(0);
    opacity: 1;
    pointer-events: all;
  }

  .mobile-close {
    position: absolute;
    top: 16px;
    right: 20px;
    background: none;
    border: none;
    color: #b4d7ff;
    font-size: 30px;
    cursor: pointer;
  }

  .contact-btn {
    background: #4bd4ff;
    color: #0f2234;
    padding: 6px 12px;
    border-radius: 8px;
    border: none;
    font-weight: 600;
    margin-right: 10px;
    text-decoration: none;
    transition: transform .2s ease, box-shadow .2s ease;
  }

  .contact-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 0 12px rgba(75, 212, 255, 0.5);
  }

  .contact-btn {
    background: #4bd4ff;
    color: #0f2234;
    padding: 6px 12px;
    border-radius: 8px;
    border: none;
    font-weight: 600;
    margin-right: 10px;
    text-decoration: none;
    transition: transform .2s ease, box-shadow .2s ease;
  }

  .contact-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 0 12px rgba(75, 212, 255, 0.5);
  }

  .mobile-link {
    font-size: 1.2rem;
    color: #cde8ff;
    text-decoration: none;
    letter-spacing: .03em;
  }

  .mobile-link:hover {
    color: #a2eeff;
  }

  .mobile-lang {
    margin-top: 16px;
  }

  .nav-link {
    color: #e7f3ff;
    transition: color .2s ease;
    position: relative;
  }

  .nav-link:hover,
  .nav-link.active {
    color: #7adeff;
  }

  .nav-link.active::after {
    content: '';
    display: block;
    height: 2px;
    width: 100%;
    background: #5bceff;
    margin-top: 4px;
    border-radius: 99px;
  }


  .brand{
    padding: 8px 14px;
    border-radius: 12px;
    background: rgba(79, 163, 255, 0.1);
    border: 1px solid rgba(79, 163, 255, 0.3);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .brand:hover {
    background: rgba(79, 163, 255, 0.15);
    border-color: rgba(79, 163, 255, 0.5);
    transform: scale(1.05);
  }

  .logo{
    height: 48px;
    width: auto;
    filter: drop-shadow(0 0 16px rgba(79, 163, 255, 0.5));
    transition: transform 0.2s ease, filter 0.2s ease;
    transform: translateY(-1px);
  }

  .brand:hover .logo {
    transform: scale(1.1);
    filter: drop-shadow(0 0 24px rgba(79, 163, 255, 0.75));
    animation: logoGlow 2.4s ease-in-out infinite;
  }

  @keyframes logoGlow {
    0%, 100% { filter: drop-shadow(0 0 22px rgba(79, 163, 255, 0.7)); transform: scale(1.08); }
    50% { filter: drop-shadow(0 0 30px rgba(18, 150, 255, 0.9)); transform: scale(1.12); }
  }

  .links {
    display: flex;
    align-items: center;
    gap: 8px;
    flex: 1;
    justify-content: center;
  }

  .right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .hamburger {
    display: none;
    background: transparent;
    border: 0;
    width: 28px;
    height: 26px;
    cursor: pointer;
    padding: 0;
  }

  @media (max-width: 860px) {
    .mobile-menu.open {
      transform: translateY(0);
      opacity: 1;
      pointer-events: all;
    }

    .contact-btn {
      display: none;
    }
  }


  .hamburger span {
    display: block;
    height: 2px;
    width: 100%;
    background: #b6d9ff;
    margin: 5px 0;
    border-radius: 999px;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(12, 20, 33, 0.97);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 20px;
    padding: 2.5rem 1.5rem;
    transform: translateY(-100%);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.3s ease, opacity 0.3s ease;
    z-index: 18;
  }

  .mobile-menu.open {
    transform: translateY(0);
    opacity: 1;
    pointer-events: all;
  }

  .mobile-close {
    position: absolute;
    top: 16px;
    right: 20px;
    background: none;
    border: none;
    color: #b4d7ff;
    font-size: 30px;
    cursor: pointer;
  }

  .mobile-link {
    font-size: 1.2rem;
    color: #cde8ff;
    text-decoration: none;
    letter-spacing: 0.03em;
  }

  .mobile-link:hover {
    color: #a2eeff;
  }

  .mobile-lang {
    margin-top: 16px;
  }

  .nav-link {
    color: #e7f3ff;
    transition: color .2s ease;
    position: relative;
  }

  .nav-link:hover,
  .nav-link.active {
    color: #7adeff;
  }

  .nav-link.active::after {
    content: '';
    display: block;
    height: 2px;
    width: 100%;
    background: #5bceff;
    margin-top: 4px;
    border-radius: 99px;
  }

  @media (max-width: 860px) {
    .hamburger { display: block; }
    .links { display: none; }

    .nav {
      padding: 12px 16px;
      gap: 10px;
    }

    .brand {
      padding: 6px 10px;
    }

    .logo {
      height: 32px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const hamburger = document.querySelector('.hamburger');
    const mobileMenu = document.getElementById('mobileMenu');
    const closeBtn = document.querySelector('.mobile-close');
    const links = document.querySelectorAll('.nav-link');

    const setActiveLink = (hash) => {
      links.forEach(link => {
        if (link.getAttribute('href') === hash) {
          link.classList.add('active');
        } else {
          link.classList.remove('active');
        }
      });
    };

    setActiveLink(window.location.hash || '#inicio');

    hamburger.addEventListener('click', () => {
      mobileMenu.classList.add('open');
      hamburger.setAttribute('aria-expanded', 'true');
      mobileMenu.setAttribute('aria-hidden', 'false');
    });

    closeBtn.addEventListener('click', () => {
      mobileMenu.classList.remove('open');
      hamburger.setAttribute('aria-expanded', 'false');
      mobileMenu.setAttribute('aria-hidden', 'true');
    });

    links.forEach(link => {
      link.addEventListener('click', () => {
        setActiveLink(link.getAttribute('href'));
        mobileMenu.classList.remove('open');
        hamburger.setAttribute('aria-expanded', 'false');
        mobileMenu.setAttribute('aria-hidden', 'true');
      });
    });
  });
</script>
