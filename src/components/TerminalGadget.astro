
<div class="terminal-wrap">
  <div class="terminal-window">
    <div class="terminal-header">
      <span class="terminal-title">root@danke</span>
      <span class="terminal-controls">
        <span class="terminal-btn minimize"></span>
        <span class="terminal-btn maximize"></span>
        <span class="terminal-btn close"></span>
      </span>
    </div>

    <pre class="terminal-body">
user@dankenet:~$ boot sequence --init
Initializing application stack...
Loading security agents...

user@dankenet:~$ agent --status --live

● PresaWatch running
● nLearning running
○ danke@cloud <span class="state muted" id="danke-cloud">loading</span>
○ main dc <span class="state muted" id="main-dc">loading</span>

user@dankenet:~$ uptime 15+ years
user@dankenet:~$ location Morelia Mich, MX
user@dankenet:~$ <span class="cursor">▌</span>
    </pre>
  </div>
</div>

<style>
/* ===== TERMINAL GADGET (Ubuntu/Linux Style) ===== */

.terminal-wrap {
  display: flex;
  justify-content: center;
  margin: 80px 0;
  padding: 0 20px;
}

.terminal-window {
  width: 100%;
  max-width: 620px;
  background: rgba(11, 14, 22, 0.95);
  border-radius: 12px;
  box-shadow: 0 24px 80px rgba(0,0,0,0.65), inset 0 0 0 1px rgba(255,255,255,0.06);
  overflow: hidden;
  border: 1px solid rgba(79, 173, 255, 0.22);
  font-family: "Ubuntu Mono", monospace;
  position: relative;
}

.terminal-window::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 12px;
  padding: 2px;
  background: linear-gradient(120deg, rgba(54, 177, 255, 0.4), rgba(122, 96, 255, 0.4), rgba(75, 235, 166, 0.4));
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: destination-out;
          mask-composite: exclude;
  pointer-events: none;
  animation: glowShift 4.5s ease-in-out infinite;
}

.terminal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 18px;
  background: linear-gradient(180deg, rgba(35, 42, 56, 0.92) 0%, rgba(20, 27, 38, 0.92) 100%);
  border-bottom: 1px solid rgba(129, 160, 255, 0.3);
}


.terminal-title {
  font-size: 0.85rem;
  color: #c8d5ff;
  font-weight: 600;
  letter-spacing: 0.5px;
}

.terminal-controls {
  display: flex;
  gap: 8px;
}

.terminal-btn {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  cursor: pointer;
  background: #555;
}

.terminal-btn.minimize {
  background: #f0ad4e;
}

.terminal-btn.maximize {
  background: #5cb85c;
}

.terminal-btn.close {
  background: #d9534f;
}

.terminal-body {
  padding: 20px 24px;
  font-family: "Ubuntu Mono", "Courier New", monospace;
  font-size: 0.92rem;
  line-height: 1.62;
  color: #7cff9d;
  white-space: pre-wrap;
  word-wrap: break-word;
  background: radial-gradient(circle at 20% 20%, rgba(25, 36, 47, 0.92), rgba(11, 15, 21, 0.85) 45%, rgba(6, 9, 15, 0.98));
  text-shadow: 0 0 14px rgba(118, 255, 155, 0.32);
  overflow-x: hidden;
  letter-spacing: 0.03em;
}

.prompt { color: #9be7ff; }
.path { color: #7de7ff; }
.ok { color: #88ff9b; }
.idle { color: #f4ff8f; }
.state { color: #96d7ff; }
.state.muted { color: #b0c4d3; }
.cursor {
  display: inline-block;
  color: #72ff8e;
  visibility: visible;
}

.cursor.hidden {
  visibility: hidden;
}

@media (max-width: 640px) {
  .terminal-wrap { margin: 60px 12px; }
  .terminal-window { max-width: 100%; }
  .terminal-body { font-size: 0.74rem; padding: 14px 16px; }
}

@keyframes glowShift {
  0%, 100% { transform: scale(1) rotate(0deg); opacity: 1; }
  50% { transform: scale(1.02) rotate(2deg); opacity: 0.86; }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const pre = document.querySelector('.terminal-body');
  const terminalText = `
user@dankenet:~$ boot sequence --init
Initializing application stack...
Loading security agents...

user@dankenet:~$ agent --status --live

● PresaWatch running
● nLearning running
○ danke@cloud loading
○ main dc loading

user@dankenet:~$ uptime 15+ years
user@dankenet:~$ location Morelia Mich, MX
`;

  const typingSpeed = 26;
  pre.textContent = '';
  let idx = 0;

  const renderFormatted = () => {
    pre.innerHTML = terminalText
      .replace(/user@dankenet/g, '<span class="prompt">user@dankenet</span>')
      .replace(/~/g, '<span class="path">~</span>')
      .replace(/●/g, '<span class="ok">●</span>')
      .replace(/○/g, '<span class="idle">○</span>')
      .replace(/PresaWatch running/g, 'PresaWatch <span class="state ok pwatch">running</span>')
      .replace(/nLearning running/g, 'nLearning <span class="state ok nlearn">running</span>')
      .replace(/danke@cloud loading/g, 'danke@cloud <span class="state muted" id="danke-cloud">loading</span>')
      .replace(/main dc loading/g, 'main dc <span class="state muted" id="main-dc">loading</span>');

    const cursorSpan = document.createElement('span');
    cursorSpan.className = 'cursor';
    cursorSpan.textContent = '▌';
    pre.appendChild(cursorSpan);
  };

  let cursorInterval;
  const startCursorBlink = () => {
    const cursor = document.querySelector('.cursor');
    if (!cursor) return;
    if (cursorInterval) clearInterval(cursorInterval);
    cursor.style.opacity = '1';
    cursorInterval = setInterval(() => {
      cursor.style.opacity = cursor.style.opacity === '0' ? '1' : '0';
    }, 500);
  };

  const typeWriter = () => {
    if (idx < terminalText.length) {
      pre.textContent += terminalText[idx];
      idx += 1;
      setTimeout(typeWriter, typingSpeed);
    } else {
      renderFormatted();
      startLoadingDots();
      startStatusToggle();
      startCursorBlink();
    }
  };

  const startLoadingDots = () => {
    const edges = [
      { id: 'danke-cloud' },
      { id: 'main-dc' }
    ];

    let dots = 0;
    setInterval(() => {
      dots = (dots % 3) + 1;
      edges.forEach(({ id }) => {
        const node = document.getElementById(id);
        if (node) {
          node.textContent = `loading${'.'.repeat(dots)}`;
        }
      });
    }, 450);
  };

  const startStatusToggle = () => {
    const services = [
      { selector: '.pwatch', up: 'running', down: 'idle' },
      { selector: '.nlearn', up: 'running', down: 'idle' }
    ];

    setInterval(() => {
      services.forEach(cfg => {
        const node = document.querySelector(cfg.selector);
        if (!node) return;
        if (node.textContent.trim() === cfg.up) {
          node.textContent = cfg.down;
          node.classList.remove('ok');
          node.classList.add('muted');
        } else {
          node.textContent = cfg.up;
          node.classList.remove('muted');
          node.classList.add('ok');
        }
      });
    }, 2200);
  };

  setTimeout(typeWriter, 400);
});
</script>
